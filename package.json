{
  "name": "prest-js-sdk",
  "version": "0.6.0",
  "description": "TypeScript SDK for pREST (PostgreSQL REST API) with typed filter DSL and optional Kratos auth",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./lobehub": {
      "types": "./dist/lobehub.d.ts",
      "import": "./dist/lobehub.js"
    }
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm run build && changeset publish",
    "gen-types": "PG_TO_TS_CONN=\"$PREST_PG_URL_LOBEHUB\" bunx pg-to-ts@4.1.1 generate --config pg-to-ts.json"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "typescript": "^5.7.2"
  }
}
